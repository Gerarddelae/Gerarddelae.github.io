---
import { SITE_TITLE, SITE_TAGLINE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Ava from '@src/assets/img/ava1.png';
import Prose from '../components/Prose.astro';
import { projects } from '../data/projects';
import ProjectList from '../components/ProjectList.astro'
import PostItem from '../components/PostItem.astro';
import Skills from '../components/Skills.astro';

type BlogPost = CollectionEntry<'blog'>;

const top6Projects = projects.slice(0, 6);
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 5);
---

<BaseLayout title={SITE_TITLE + ' - ' + SITE_TAGLINE} description={SITE_DESCRIPTION}>
	<div class='container' style="position: relative; overflow: hidden;">
		<!-- Modern Background Blobs -->
		<div class="bg-blobs" aria-hidden="true">
			<div class="blob blob-1"></div>
			<div class="blob blob-2"></div>
			<div class="blob blob-3"></div>
		</div>

		<div class='w-full md:flex md:items-center gap-16 mb-16 pt-8' style="position: relative; z-index: 2;">
			<div style="flex: 1;">
				<h1 style="font-family: 'Outfit', sans-serif; font-size: 3rem; font-weight: 800; line-height: 1.2; margin-bottom: 1.5rem; color: var(--color-text); letter-spacing: -0.02em;">
					¡Hola! 👋, <span class="gradient-text">Soy Gerardo!</span>
				</h1>
				<div style="margin-bottom: 1.5rem;">
					<span id="typing-role" style="font-size: 1.25rem; font-weight: 600; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;"></span>
				</div>
				<Prose>
					<div style="font-size: 1.125rem; line-height: 1.7; margin-top: 1rem;">
						<p style="text-align: justify; color: var(--color-text-secondary);">
							<strong style="color: var(--color-text);">Ingeniero Civil y Desarrollador Full Stack.</strong> 
							Apasionado por construir el futuro tanto física como digitalmente. Combino la precisión del diseño estructural con la agilidad del desarrollo de software para crear soluciones robustas, eficientes y sostenibles.
						</p>
					</div>
				</Prose>
				<div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 2rem;">
					<a href="/projects/" class="btn-primary">
						Ver proyectos
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 0.5rem;"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
					<a href="https://linkedin.com/in/#" target="_blank" class="btn-icon" aria-label="LinkedIn">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
					</a>
				</div>
			</div>
			<div class="hero-image-container">
				<div class="image-glow"></div>
				<Image src={Ava} alt="Gerardo de la Espriella" width={320} loading="eager" class="hero-image"/>
				<div class="image-decoration-1"></div>
				<div class="image-decoration-2"></div>
			</div>
		</div>

		<main style="position: relative; z-index: 2;">
			<Skills />
			
			<div style="margin-top: 4rem; margin-bottom: 4rem;">
				<div style="display: flex; justify-content: space-between; align-items: center; gap: 0.5rem; border-bottom: 1px solid var(--color-border); margin-bottom: 0.25rem;">
					<h2 style="font-size: 1.125rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--color-text);">Artículos Recientes</h2>
					<a href="/posts/" style="display: inline-block; padding: 0.5rem 0; text-decoration: underline; color: var(--color-text-secondary);">Todos los artículos &raquo;</a>
				</div>
				<div>
					{posts.map((post: BlogPost) => (
						<PostItem post={post} />
					))}      
				</div>
			</div>
			<div>
				<div style="display: flex; justify-content: space-between; align-items: center; gap: 0.5rem; margin-bottom: 0.25rem;">
					<h2 style="font-size: 1.125rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--color-text);">Mis Proyectos</h2>
					<a href="/projects/" style="display: inline-block; padding: 0.5rem 0; text-decoration: underline; color: var(--color-text-secondary);">Todos los proyectos &raquo;</a>
				</div>
				<ProjectList projects={top6Projects}/>
			</div>
		</main>
	</div>
</BaseLayout>

<script>
	const roles = [
		'Ingeniero Civil',
		'Desarrollador Full Stack',
		'Especialista en Next.js',
		'Creador de soluciones',
		'Apasionado por ML'
	];
	
	const typingElement = document.getElementById('typing-role');
	let roleIndex = 0;
	let charIndex = 0;
	let isDeleting = false;
	let typingTimeout: ReturnType<typeof setTimeout>;

	function typeRole() {
		if (!typingElement) return;
		
		const currentRole = roles[roleIndex];
		
		if (isDeleting) {
			typingElement.textContent = currentRole.substring(0, charIndex - 1);
			charIndex--;
		} else {
			typingElement.textContent = currentRole.substring(0, charIndex + 1);
			charIndex++;
		}

		let typeSpeed = isDeleting ? 50 : 100;

		if (!isDeleting && charIndex === currentRole.length) {
			typeSpeed = 2000;
			isDeleting = true;
		} else if (isDeleting && charIndex === 0) {
			isDeleting = false;
			roleIndex = (roleIndex + 1) % roles.length;
			typeSpeed = 500;
		}

		typingTimeout = setTimeout(typeRole, typeSpeed);
	}

	setTimeout(typeRole, 1000);

	document.addEventListener('astro:before-swap', () => {
		clearTimeout(typingTimeout);
	});
</script>

<style>
	#typing-role {
		display: inline-block;
		min-height: 1.5rem;
	}

	#typing-role::after {
		content: '|';
		animation: blink 0.75s step-end infinite;
		margin-left: 2px;
		color: var(--color-accent);
	}

	@keyframes blink {
		50% { opacity: 0; }
	}

	img:hover {
		transform: scale(1.02);
	}

	.gradient-text {
		background: linear-gradient(135deg, var(--color-accent) 0%, #60a5fa 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	/* Buttons */
	.btn-primary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.75rem 1.5rem;
		border-radius: 0.75rem;
		font-weight: 600;
		background: linear-gradient(135deg, var(--color-accent) 0%, #3b82f6 100%);
		color: white;
		text-decoration: none;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 20px rgba(59, 130, 246, 0.4);
		filter: brightness(1.1);
	}

	.btn-outline {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.75rem 1.5rem;
		border-radius: 0.75rem;
		font-weight: 600;
		border: 1px solid var(--color-border);
		background: rgba(var(--color-bg), 0.5);
		backdrop-filter: blur(8px);
		color: var(--color-text);
		text-decoration: none;
		transition: all 0.3s;
	}

	.btn-outline:hover {
		background: var(--color-bg-secondary);
		border-color: var(--color-accent);
		color: var(--color-accent);
		transform: translateY(-2px);
	}

	.btn-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.25rem;
		height: 3.25rem;
		border-radius: 0.75rem;
		border: 1px solid var(--color-border);
		background: rgba(var(--color-bg), 0.5);
		backdrop-filter: blur(8px);
		color: var(--color-text-secondary);
		transition: all 0.3s;
	}

	.btn-icon:hover {
		color: var(--color-accent);
		border-color: var(--color-accent);
		background: color-mix(in srgb, var(--color-accent) 10%, transparent);
		transform: translateY(-2px) rotate(5deg);
	}

	/* Background Blobs */
	.bg-blobs {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		overflow: hidden;
		pointer-events: none;
		z-index: 0;
		opacity: 0.4;
	}

	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		animation: float-blob 20s infinite alternate;
	}

	.blob-1 {
		top: -10%;
		left: -10%;
		width: 40%;
		height: 40%;
		background: rgba(59, 130, 246, 0.15);
	}

	.blob-2 {
		top: 20%;
		right: -5%;
		width: 35%;
		height: 35%;
		background: rgba(147, 51, 234, 0.1);
		animation-delay: -5s;
	}

	.blob-3 {
		bottom: 10%;
		left: 20%;
		width: 30%;
		height: 30%;
		background: rgba(59, 130, 246, 0.1);
		animation-delay: -10s;
	}

	@keyframes float-blob {
		0% { transform: translate(0, 0) scale(1); }
		100% { transform: translate(10%, 15%) scale(1.1); }
	}

	/* Hero Image */
	.hero-image-container {
		position: relative;
		perspective: 1000px;
	}

	.hero-image {
		border-radius: 2rem;
		position: relative;
		z-index: 2;
		transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.hero-image:hover {
		transform: translateY(-10px) rotateY(-5deg) rotateX(5deg);
		box-shadow: 0 30px 60px rgba(59, 130, 246, 0.2);
	}

	.image-glow {
		position: absolute;
		inset: -20px;
		background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);
		opacity: 0.2;
		filter: blur(40px);
		z-index: 1;
		animation: pulse-glow 4s infinite alternate;
	}

	.image-decoration-1 {
		position: absolute;
		top: -1rem;
		right: -1rem;
		width: 5rem;
		height: 5rem;
		border: 2px dashed color-mix(in srgb, var(--color-accent) 30%, transparent);
		border-radius: 50%;
		animation: rotate 15s linear infinite;
		z-index: 3;
	}

	.image-decoration-2 {
		position: absolute;
		bottom: -1.5rem;
		left: -1.5rem;
		width: 3rem;
		height: 3rem;
		background: var(--color-accent);
		opacity: 0.2;
		border-radius: 1rem;
		animation: float 6s ease-in-out infinite;
		z-index: 3;
	}

	@keyframes rotate {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	@keyframes pulse-glow {
		0% { opacity: 0.1; transform: scale(0.9); }
		100% { opacity: 0.3; transform: scale(1.1); }
	}
</style>
