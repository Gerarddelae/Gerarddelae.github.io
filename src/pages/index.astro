---
import { SITE_TITLE, SITE_TAGLINE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Ava from '@src/assets/img/ava1.png';
import Prose from '../components/Prose.astro';
import { projects } from '../data/projects';
import ProjectList from '../components/ProjectList.astro'
import PostItem from '../components/PostItem.astro';

type BlogPost = CollectionEntry<'blog'>;

const top6Projects = projects.slice(0, 6);
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 5);
---

<BaseLayout title={SITE_TITLE + ' - ' + SITE_TAGLINE} description={SITE_DESCRIPTION}>
	<div class='container' style="position: relative;">
		<div style="position: absolute; inset: 0; background: radial-gradient(at 40% 20%, var(--color-accent) 0px, transparent 50%), radial-gradient(at 80% 0%, var(--color-accent-secondary) 0px, transparent 50%), radial-gradient(at 0% 50%, var(--color-accent) 0px, transparent 50%); opacity: 0.03; pointer-events: none;"></div>
		<div class='w-full md:flex md:items-center gap-16 mb-10' style="position: relative;">
			<div style="flex: 1;">
				<h1 style="font-family: 'Outfit', sans-serif; font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem; color: var(--color-text);">
					¡Hola! 👋, Soy Gerardo!
				</h1>
				<div style="margin-bottom: 1rem;">
					<span id="typing-role" style="font-size: 1.125rem; font-weight: 500; color: var(--color-accent);"></span>
				</div>
				<Prose>
					<div style="font-size: 1.125rem; margin-top: 1rem;">
						<p style="text-align: justify; color: var(--color-text-secondary);">Ingeniero Civil, Analista y Desarrollador de Software
							Apasionado por construir el futuro tanto física como digitalmente, combino mi experiencia en Ingeniería Civil con mis habilidades como Analista y Desarrollador de Software para crear soluciones innovadoras, eficientes y sostenibles. Actualmente me encuentro estudiando temas de Machine Learning para ofrecer soluciones más integrales. Con una sólida base en diseño estructural, gestión de proyectos y desarrollo de software, aporto precisión y capacidades de resolución de problemas, desarrollando aplicaciones robustas que generan impacto.</p>
					</div>
				</Prose>
				<div style="display: flex; gap: 0.75rem; margin-top: 1.5rem;">
					<a href="/projects/" style="display: inline-flex; align-items: center; justify-content: center; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-weight: 500; background-color: var(--color-accent); color: white; text-decoration: none; transition: all 0.3s;">
						Ver proyectos
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 0.25rem;"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
					<a href="/about/" style="display: inline-flex; align-items: center; justify-content: center; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-weight: 500; border: 1px solid var(--color-border); background: transparent; color: var(--color-text); text-decoration: none; transition: all 0.3s;">Sobre mí</a>
				</div>
			</div>
			<div style="position: relative;">
				<div style="position: absolute; inset: 0; border-radius: 1.5rem; filter: blur(40px); animation: pulseGlow 2s ease-in-out infinite; background-color: color-mix(in srgb, var(--color-accent) 20%, transparent);"></div>
				<Image src={Ava} alt="Gerardo de la Espriella" width={300} loading="eager" style="border-radius: 1.5rem; position: relative; z-index: 1; transition: transform 0.3s;"/>
				<div style="position: absolute; top: -0.5rem; right: -0.5rem; width: 4rem; height: 4rem; border: 2px dashed; border-radius: 50%; animation: float 6s ease-in-out infinite; border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);"></div>
				<div style="position: absolute; bottom: -0.75rem; left: -0.75rem; width: 2.5rem; height: 2.5rem; border-radius: 50%; animation: float 6s ease-in-out infinite; animation-delay: -2s; background-color: color-mix(in srgb, var(--color-accent) 10%, transparent);"></div>
			</div>
		</div>
		<main>
			<div style="margin-top: 1.5rem; margin-bottom: 3rem;">
				<div style="display: flex; justify-content: space-between; align-items: center; gap: 0.5rem; border-bottom: 1px solid var(--color-border); margin-bottom: 0.25rem;">
					<h2 style="font-size: 1.125rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--color-text);">Recent Posts</h2>
					<a href="/posts/" style="display: inline-block; padding: 0.5rem 0; text-decoration: underline; color: var(--color-text-secondary);">All posts &raquo;</a>
				</div>
				<div>
					{posts.map((post: BlogPost) => (
						<PostItem post={post} />
					))}      
				</div>
			</div>
			<div>
				<div style="display: flex; justify-content: space-between; align-items: center; gap: 0.5rem; margin-bottom: 0.25rem;">
					<h2 style="font-size: 1.125rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--color-text);">My Projects</h2>
					<a href="/projects/" style="display: inline-block; padding: 0.5rem 0; text-decoration: underline; color: var(--color-text-secondary);">All projects &raquo;</a>
				</div>
				<ProjectList projects={top6Projects}/>
			</div>
		</main>
	</div>
</BaseLayout>

<script>
	const roles = [
		'Ingeniero Civil',
		'Desarrollador Full Stack',
		'Creador de soluciones',
		'Apasionado por ML'
	];
	
	const typingElement = document.getElementById('typing-role');
	let roleIndex = 0;
	let charIndex = 0;
	let isDeleting = false;
	let typingTimeout: ReturnType<typeof setTimeout>;

	function typeRole() {
		if (!typingElement) return;
		
		const currentRole = roles[roleIndex];
		
		if (isDeleting) {
			typingElement.textContent = currentRole.substring(0, charIndex - 1);
			charIndex--;
		} else {
			typingElement.textContent = currentRole.substring(0, charIndex + 1);
			charIndex++;
		}

		let typeSpeed = isDeleting ? 50 : 100;

		if (!isDeleting && charIndex === currentRole.length) {
			typeSpeed = 2000;
			isDeleting = true;
		} else if (isDeleting && charIndex === 0) {
			isDeleting = false;
			roleIndex = (roleIndex + 1) % roles.length;
			typeSpeed = 500;
		}

		typingTimeout = setTimeout(typeRole, typeSpeed);
	}

	setTimeout(typeRole, 1000);

	document.addEventListener('astro:before-swap', () => {
		clearTimeout(typingTimeout);
	});
</script>

<style>
	#typing-role {
		display: inline-block;
		min-height: 1.5rem;
	}

	#typing-role::after {
		content: '|';
		animation: blink 0.75s step-end infinite;
		margin-left: 2px;
		color: var(--color-accent);
	}

	@keyframes blink {
		50% { opacity: 0; }
	}

	img:hover {
		transform: scale(1.02);
	}
</style>
