---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectList from '../../components/ProjectList.astro';
import { projects } from '../../data/projects';

const allProjects = projects;
---

<BaseLayout
	title="Mis Proyectos | Gerardo"
	description="Una colección de mis trabajos, desde aplicaciones full-stack hasta experimentos de IA y contribuciones de código abierto."
>
  <div class='container'>
    <div class="mb-10 animate-fade-up">
      <h1 class="text-5xl font-black mb-4 tracking-tight">Mis Proyectos</h1>
      <p class="text-[var(--color-text-secondary)] text-xl leading-relaxed max-w-2xl">Una colección curada de mis trabajos, que abarca desde aplicaciones full-stack hasta experimentos de IA y contribuciones de código abierto.</p>
    </div>
    <ProjectList projects={allProjects}/>
  </div>
</BaseLayout>
