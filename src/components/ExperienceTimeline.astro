---
const experiences = [
  {
    year: '2025 - Presente',
    title: 'Analista y Desarrollador de Software',
    company: 'Proyectos Freelance & E-commerce',
    description: 'Especializado en el desarrollo de plataformas e-commerce utilizando tecnologías modernas como Next.js, Angular y Spring Boot. Enfocado en el diseño de arquitecturas escalables y la optimización de procesos para garantizar soluciones de alto impacto y eficiencia técnica.',
    icon: '💻'
  },
  {
    year: '2024 - 2025',
    title: 'Bootcamp en Desarrollo de Software',
    company: 'Programa Talento Tech (MinTIC Colombia)',
    description: 'Formación intensiva centrada en arquitecturas modernas, desarrollo Full Stack y metodologías ágiles, consolidando una base técnica sólida para proyectos complejos.',
    icon: '🎓'
  },
  {
    year: '2022 - 2024',
    title: 'Ingeniería Civil & Análisis de Datos',
    company: 'Proyectos Estructurales',
    description: 'Gestión de proyectos y diseño estructural aplicando herramientas digitales para la optimización de procesos.',
    icon: '🏗️'
  },
  {
    year: '2021',
    title: 'Inicio en Programación',
    company: 'Autodidacta',
    description: 'Primeros pasos en algoritmos, estructuras de datos y desarrollo web para automatizar tareas de ingeniería.',
    icon: '🚀'
  }
];
---

<div class="timeline">
  {experiences.map((exp, index) => (
    <div class="timeline-item" style={`--delay: ${index * 0.2}s`}>
      <div class="timeline-dot"></div>
      <div class="timeline-content">
        <div class="header">
          <span class="year">{exp.year}</span>
          <span class="icon">{exp.icon}</span>
        </div>
        <h3 class="title">{exp.title}</h3>
        <p class="company">{exp.company}</p>
        <p class="description">{exp.description}</p>
      </div>
    </div>
  ))}
</div>

<style>
  .timeline {
    position: relative;
    max-width: 800px;
    margin: 3rem auto;
    padding: 0 0.5rem;
  }

  /* Vertical line */
  .timeline::before {
    content: '';
    position: absolute;
    left: 1.25rem;
    top: 1rem;
    bottom: 0;
    width: 2px;
    background: var(--color-border);
    opacity: 0.5;
  }

  .timeline-item {
    position: relative;
    padding-left: 2.5rem;
    margin-bottom: 2rem;
    opacity: 0;
    transform: translateY(20px);
    animation: reveal 0.8s forwards;
    animation-delay: var(--delay);
  }

  @keyframes reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .timeline-dot {
    position: absolute;
    left: 0.75rem;
    top: 0.5rem;
    width: 1rem;
    height: 1rem;
    background: var(--color-accent);
    border-radius: 50%;
    border: 4px solid var(--color-bg);
    box-shadow: 0 0 0 2px var(--color-accent);
    z-index: 2;
  }

  .timeline-content {
    background: var(--color-bg-secondary);
    backdrop-filter: blur(10px);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1rem;
    transition: all 0.3s;
  }

  .timeline-content:hover {
    border-color: var(--color-accent);
    transform: translateX(4px);
    background: var(--color-bg-secondary);
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.2);
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .year {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 15%, transparent);
    padding: 0.25rem 0.5rem;
    border-radius: 99px;
  }

  .icon { font-size: 1.25rem; }

  .title {
    font-size: 1rem;
    font-weight: 800;
    margin: 0.5rem 0 0.25rem 0;
    color: var(--color-text);
  }

  .company {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
  }

  .description {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0;
  }

  @media (min-width: 768px) {
    .timeline {
      padding: 0 1rem;
    }

    .timeline::before {
      left: 2rem;
    }

    .timeline-item {
      padding-left: 4rem;
      margin-bottom: 3rem;
    }

    .timeline-dot {
      left: 1.5rem;
      top: 0.5rem;
    }

    .timeline-content {
      padding: 1.5rem;
      border-radius: 1.5rem;
    }

    .timeline-content:hover {
      transform: translateX(10px);
    }

    .year {
      font-size: 0.875rem;
      padding: 0.25rem 0.75rem;
    }

    .title {
      font-size: 1.25rem;
    }

    .company {
      font-size: 0.9rem;
    }

    .description {
      font-size: 1rem;
      line-height: 1.6;
    }
  }
</style>
