---
const skills = [
  { name: 'Angular', level: 'Expert', icon: '🅰️', category: 'Frontend' },
  { name: 'Astro', level: 'Advanced', icon: '🚀', category: 'Frontend' },
  { name: 'Spring Boot', level: 'Expert', icon: '🍃', category: 'Backend' },
  { name: 'Python', level: 'Advanced', icon: '🐍', category: 'Backend / ML' },
  { name: 'Machine Learning', level: 'Intermediate', icon: '🤖', category: 'Data Science' },
  { name: 'NestJS', level: 'Advanced', icon: '🪺', category: 'Backend' },
  { name: 'Next.js', level: 'Advanced', icon: '⚛️', category: 'Frontend' },
  { name: 'Ingeniería Civil', level: 'Senior', icon: '🏗️', category: 'Engineering' },
];

const categories = [...new Set(skills.map(skill => skill.category))];
---

<section class="skills-section">
  <div class="header">
    <h2 class="title">Tecnologías & Experiencia</h2>
    <div class="underline"></div>
  </div>

  <div class="skills-grid">
    {skills.map((skill) => (
      <div class="skill-card">
        <div class="icon-wrapper">{skill.icon}</div>
        <div class="info">
          <h3 class="skill-name">{skill.name}</h3>
          <p class="skill-category">{skill.category}</p>
          <div class="level-bar-bg">
            <div class={`level-bar ${skill.level.toLowerCase()}`}></div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .skills-section {
    margin: 4rem 0;
    position: relative;
    z-index: 1;
  }

  .header {
    margin-bottom: 2rem;
  }

  .title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
  }

  .underline {
    width: 3rem;
    height: 3px;
    background: var(--color-accent);
    margin-top: 0.5rem;
    border-radius: 999px;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.25rem;
  }

  .skill-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: 1rem;
    border: 1px solid var(--color-border);
    background: rgba(var(--color-bg), 0.3);
    backdrop-filter: blur(10px);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .skill-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
    box-shadow: 0 10px 20px -5px rgba(var(--color-accent), 0.1);
    background: rgba(var(--color-bg-secondary), 0.5);
  }

  .icon-wrapper {
    font-size: 1.75rem;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border-radius: 0.75rem;
    flex-shrink: 0;
  }

  .info {
    flex: 1;
  }

  .skill-name {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-text);
  }

  .skill-category {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    margin: 0.25rem 0 0.5rem 0;
  }

  .level-bar-bg {
    height: 4px;
    width: 100%;
    background: var(--color-border);
    border-radius: 99px;
    overflow: hidden;
  }

  .level-bar {
    height: 100%;
    background: var(--color-accent);
    border-radius: 99px;
  }

  .level-bar.expert { width: 95%; }
  .level-bar.senior { width: 90%; }
  .level-bar.advanced { width: 80%; }
  .level-bar.intermediate { width: 60%; }
</style>
